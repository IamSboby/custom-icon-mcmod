package com.customicon;

import net.fabricmc.api.ClientModInitializer;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

public class CustomIconClient implements ClientModInitializer {

    public static final String MOD_ID = "customicon";
    public static final Logger LOGGER = LoggerFactory.getLogger(MOD_ID);

    @Override
    public void onInitializeClient() {
        LOGGER.info("CustomIcon mod loaded - taskbar icon will be replaced with logo.png");
    }
}
