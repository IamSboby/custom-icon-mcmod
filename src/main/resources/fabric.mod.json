{
  "schemaVersion": 1,
  "id": "customicon",
  "version": "${version}",
  "name": "Custom Icon",
  "description": "Replaces the Minecraft taskbar icon with your own logo.png, no config, just drop the \"icon.png\" in the mods folder or in the instance root folder ",
  "authors": [
    "§dwavedtime",
    {
      "name": "§aSboby_",
      "contact": {
        "homepage": "https://modrinth.com/user/Sboby_"
      }
    },
    {
      "name": "§6Albuz999",
      "contact": {
        "homepage": "https://modrinth.com/user/Albuz999"
      }
    }
  ],
  "contact": {},
  "license": "MIT",
  "icon": "assets/customlogo/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.customicon.CustomIconClient"
    ],
    "modmenu": [
      "com.customicon.modmenu.CustomLogoModMenuIntegration"
    ]
  },
  "mixins": [
    "customicon.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}
